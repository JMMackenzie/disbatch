+// Default "query at a time" batch processing
+// Just run the queries in order they are given
+// This function also can implement either the clairvoyant
+// or the Q_k baseline by passing in an appropriate thresholds vector
+template <typename Fn>
+void process_query_at_a_time(
+    Fn query_func,
+    std::vector<Query> const& queries,
+    std::vector<Score> const& thresholds,
+    std::uint64_t k) {
+    
+    // Start the clock...
+    auto start = std::chrono::steady_clock::now();
+    
+    // For each query, process it
+    for (auto&& [query_idx, query]: enumerate(queries)) {
+        uint64_t result = query_func(query, thresholds[query_idx]);
+        do_not_optimize_away(result);
+    }
+    
+    auto end = std::chrono::steady_clock::now();
+    double batch_millisecs = std::chrono::duration_cast<std::chrono::milliseconds>(end - start).count();
+    double batch_secs = std::chrono::duration_cast<std::chrono::seconds>(end - start).count();
+    
+    spdlog::info("---- qaat batch millisec = {} secs = {}", batch_millisecs, batch_secs); 
+}
+
+// Static caching approach (SC) - requires a threshold F to be provided
+template <typename Fn>
+void process_static_caching(
+    Fn query_func,
+    std::vector<Query> const& queries,
+    std::uint64_t k,
+    size_t f_cutoff) {
+    
+    // Start the clock...
+    auto start = std::chrono::steady_clock::now();
+   
+    // This maps queries (represented as strings) to thresholds    
+    std::vector<subquery_mapping> subqueries = map_frequent_subqueries(queries, f_cutoff);
+
+    auto stop_map = std::chrono::steady_clock::now();
+ 
+    // Set up thresholds for querying
+    std::vector<Score> sq_thresholds(queries.size(), 0);
+    for (auto const& sq : subqueries) {
+        // Build and run the subquery
+        Query q("", sq.to_query());
+        auto result = query_func(q, 0);
+        // Map this threshold back to the associated queries
+        for (auto const& i : sq.indexes) {
+            sq_thresholds[i] = std::max(sq_thresholds[i], result);
+        }
+    }
+
+    auto stop_threshold_gen = std::chrono::steady_clock::now();
+
+    // For each query, process it
+    for (auto&& [query_idx, query]: enumerate(queries)) {
+        // You could mix and match the query_func if you wanted (since
+        // we can assume subqueries are short, you might prefer to stick
+        // to BMW here for example)
+        uint64_t result = query_func(query, sq_thresholds[query_idx]);
+        do_not_optimize_away(result);
+    }
+    
+    auto end = std::chrono::steady_clock::now();
+    double batch_millisecs = std::chrono::duration_cast<std::chrono::milliseconds>(end - start).count();
+    double batch_secs = std::chrono::duration_cast<std::chrono::seconds>(end - start).count();
+    
+    spdlog::info("---- static_cache batch millisec = {} secs = {}", batch_millisecs, batch_secs);
+
+    double mapping = std::chrono::duration_cast<std::chrono::milliseconds>(stop_map - start).count();
+    double subquery = std::chrono::duration_cast<std::chrono::milliseconds>(stop_threshold_gen - stop_map).count();
+
+    double query = std::chrono::duration_cast<std::chrono::milliseconds>(end - stop_threshold_gen).count();
+
+    spdlog::info("Breakdown (millisec): mapping = {} subquery processing = {} query processing = {}", mapping, subquery, query);
+}
+
+
+// The online dynamic caching algorithm
+// ASSUMPTION: The batch is already sorted in ascending order of query length, and
+// lexicographically within each length bucket. You can do this offline but it should
+// be counted towards the total latency.
+template <typename Fn>
+void process_dynamic_caching(
+    Fn query_func,
+    std::vector<Query> const& queries,
+    std::vector<Score> const& thresholds,
+    std::uint64_t k) {
+    
+    // Start the clock...
+    auto start = std::chrono::steady_clock::now();
+   
+    std::unordered_map<std::string, Score> score_cache;
+
+    // For each query, process it
+    for (auto&& [query_idx, query]: enumerate(queries)) {
+
+        // XXX: Change me to hr1 or hr3 if you prefer.
+        auto thresh = get_threshold_hr2(score_cache, query);
+        uint64_t result = query_func(query, thresh);
+        score_cache[query.to_string()] = result;
+        do_not_optimize_away(result);
+    }
+    
+    auto end = std::chrono::steady_clock::now();
+    double batch_millisecs = std::chrono::duration_cast<std::chrono::milliseconds>(end - start).count();
+    double batch_secs = std::chrono::duration_cast<std::chrono::seconds>(end - start).count();
+    
+    spdlog::info("---- online_cache batch millisec = {} secs = {}", batch_millisecs, batch_secs); 
+}
