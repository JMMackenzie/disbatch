+
+// Given a vector of subsets, examine the cache for all of them
+// and update `max_threshold` to the maximum one. Return true if we
+// updated; false otherwise.
+bool subset_max_exists(const std::vector<std::string>& subsets,
+                       Score& max_threshold,
+                       const std::unordered_map<std::string, Score>& cache) {
+  bool exists = false;
+
+  for (const auto& s : subsets) {
+    bool in_cache = cache.find(s) != cache.end();
+
+    if (in_cache) {
+      exists = true;
+      Score threshold = cache.at(s);
+      if (threshold > max_threshold)
+        max_threshold = threshold;
+    }
+  }
+
+  return exists;
+}
+
+// Given a vector of state pointers, produce the next
+// subset of size r; return true if a new subset is yielded,
+// or false if all subsets are exhausted.
+bool next_subset(std::vector<std::uint32_t>& ptrs,
+                 const std::vector<std::uint32_t>& end_ptrs,
+                 uint32_t r) {
+  for (int i = r - 1; i > -1; i--) {
+    if (ptrs[i] < end_ptrs[i]) {
+      ptrs[i]++;
+      uint32_t moved = ptrs[i];
+      for (int j = i + 1; j < r; j++) {
+        ptrs[j] = moved + 1;
+        moved++;
+      }
+      return true;
+    }
+  }
+  return false;
+}
+
+// Generate all subsets of size r for a given vector of query
+// terms. Here, the terms are already mapped to integers.
+std::vector<std::string> gen_subsets(const std::vector<TermId>& terms,
+                                     std::uint32_t r) {
+  uint32_t n = terms.size();
+  std::vector<std::string> subsets;
+
+  if (r <= n && r > 0) {
+    std::vector<std::uint32_t> ptrs(r);
+    std::iota(std::begin(ptrs), std::end(ptrs), 0);
+
+    std::vector<std::uint32_t> end_ptrs(r);
+    std::iota(std::begin(end_ptrs), std::end(end_ptrs), n - r);
+
+    do {
+      std::string subset = std::to_string(terms[ptrs[0]]);
+
+      for (int i = 1; i < r; i++) {
+        subset += " " + std::to_string(terms[ptrs[i]]);
+      }
+      subsets.push_back(subset);
+
+    } while (next_subset(ptrs, end_ptrs, r));
+  }
+
+  return subsets;
+}
+
+// HR1 Policy
+// All queries are unique, so if you are given a 2-term query, you do not try
+// to find the 2-term pair in the cache, just each singleton term.
+Score get_threshold_hr1(const std::unordered_map<std::string, Score>& score_cache, const Query& query) {
+
+  // HR-1: Probe for triplets, pairs, and then terms.
+  // If we hit multiple in a group, we use the maximum.
+  // We return as soon as a group is hit and enumerated.
+  Score threshold = 0;
+  std::vector<TermId> tokens = query.term_ids();
+  size_t len_tokens = tokens.size();
+
+  // Try triplets
+  if (len_tokens > 3) {
+    // We hit, so we return
+    if (subset_max_exists(gen_subsets(tokens, 3), threshold, score_cache)) {
+      return threshold;
+    }
+  }
+
+  // Try pairs
+  if (len_tokens > 2) {
+    // We hit, so we return
+    if (subset_max_exists(gen_subsets(tokens, 2), threshold, score_cache))
+      return threshold;
+  }
+
+  // Try singles
+  if (len_tokens > 1) {
+    subset_max_exists(gen_subsets(tokens, 1), threshold, score_cache);
+  }
+  // Return what we found
+  return threshold;
+}
+
+// HR-2: Same as HR-1 but we do not back out once we hit the cache.
+Score get_threshold_hr2(const std::unordered_map<std::string, Score>& score_cache, const Query& query) {
+
+  Score threshold = 0;
+  std::vector<TermId> tokens = query.term_ids();
+  size_t len_tokens = tokens.size();
+
+  // Try triplets
+  if (len_tokens > 3) {
+    subset_max_exists(gen_subsets(tokens, 3), threshold, score_cache);
+  }
+
+  // Try pairs
+  if (len_tokens > 2) {
+    subset_max_exists(gen_subsets(tokens, 2), threshold, score_cache);
+  }
+
+  // Try singles
+  if (len_tokens > 1) {
+    subset_max_exists(gen_subsets(tokens, 1), threshold, score_cache);
+  }
+
+  // Return the largest we found
+  return threshold;
+}
+
+// HR-3: Only look at |q|-1 sized subsets.
+Score get_threshold_hr3(const std::unordered_map<std::string, Score>& score_cache, const Query& query) {
+  Score threshold = 0;
+  std::vector<TermId> tokens = query.term_ids();
+  size_t len_tokens = tokens.size();
+  subset_max_exists(gen_subsets(tokens, len_tokens - 1), threshold, score_cache);
+  return threshold;
+}
+
+// END Yafay and Altingovde Snippets **********************************************************************************
