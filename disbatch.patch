+// Offline Batch QP Structures here
+
+// Maps each subquery to the (index of) queries that contain it in the original input log
+struct subquery_mapping {
+  std::string subquery;
+  std::vector<size_t> indexes;
+
+  subquery_mapping() {}
+  subquery_mapping(std::string s, std::vector<size_t> idx) : subquery(s), indexes(idx) {}
+
+  std::vector<TermId> to_query() const {
+    std::stringstream ss(subquery);
+    std::vector<TermId> terms;
+    TermId term;
+    while (ss >> term) {
+      terms.push_back(term);
+    }
+    return terms;
+  }
+
+};
+
+// Core logic of the offline caching setup.
+// Walks the queries and finds a list of subqueries appearing more than f times.
+// This is the "generating" + "subquery to query mapping" + "filtering" steps
+// of the static caching approach
+std::vector<subquery_mapping> map_frequent_subqueries(std::vector<Query> const& queries, size_t f_cutoff) {
+
+  std::unordered_map<std::string, std::vector<size_t>> subquery_to_query;
+  std::vector<subquery_mapping> subquery_data;
+  size_t idx = 0;
+
+  // 1. Walk the queries and generate subqueries
+  for (auto const& query: queries) {
+    
+    auto query_terms = query.term_ids();
+    
+    // Singleton terms
+    auto subqueries = gen_subsets(query_terms, 1);
+    for (const auto& q : subqueries) {
+        subquery_to_query[q].push_back(idx);
+    }
+
+    // Pairs of terms
+    subqueries = gen_subsets(query_terms, 2);
+    for (const auto& q : subqueries) {
+        subquery_to_query[q].push_back(idx);
+    }
+
+    // Triplets of terms
+    subqueries = gen_subsets(query_terms, 3);
+    for (const auto& q : subqueries) {
+        subquery_to_query[q].push_back(idx);
+    }
+    
+    idx += 1;
+  }
+  
+  // Now we filter the subqueries of interest
+  for (auto& it: subquery_to_query) {
+    if (it.second.size() >= f_cutoff) {
+      subquery_data.emplace_back(it.first, it.second);
+    }
+  }
+
+  /* You can print stats if you like
+  // Stats
+  std::cerr << "Kept: " << subquery_data.size() << " subqueries\n";
+  size_t total = 0;
+  for (size_t i = 0; i < subquery_data.size(); ++i) {
+    total += subquery_data[i].indexes.size();
+  }
+  std::cerr << "Mapping to a total of " << total << " indexes\n";
+  */
+
+  return subquery_data;
+}
